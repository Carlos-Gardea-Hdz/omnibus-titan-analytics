APP_NAME="Titan Analytics"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Bilingual UI (ES/EN) — default to Spanish per OMNIBUS standards.
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file

# Argon2id/bcrypt cost. Keep >= 12 in production (security-2026.md §6).
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- OLTP: PostgreSQL 18 (accounts, projects, API keys, consent records) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=titan_analytics
DB_USERNAME=titan
DB_PASSWORD=
# Use 'require' (or 'verify-full' in prod) — never disable TLS to the DB.
DB_SSLMODE=prefer

# Session/cache/queue on Valkey 8 (Redis protocol). Server-side sessions.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Secure cookies in any non-local environment (no insecure default).
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# --- Valkey 8 (cache + queue + session) ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Columnar event store: ClickHouse (26.3 LTS) ---
# Least privilege: a read-only user here for dashboards; the loader uses an
# INSERT-only user. TLS is mandatory (port 8443). Never a superuser.
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8443
CLICKHOUSE_DATABASE=titan_analytics
CLICKHOUSE_USERNAME=titan_ro
CLICKHOUSE_PASSWORD=

# --- Analytics / privacy ---
# Base secret for the rotating daily session salt (cookieless ephemeral IDs).
ANALYTICS_SESSION_SALT=
ANALYTICS_MAX_BATCH=1000
ANALYTICS_MAX_BODY_BYTES=524288
ANALYTICS_MAX_JSON_DEPTH=8
# Retention ceiling for consent-free collection (months).
ANALYTICS_RETENTION_MONTHS=13

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
